strict-peer-dependencies=false
# This is a workaround for VSCode's Eslint extension not loading plugins correctly,
# see: https://github.com/pnpm/pnpm/issues/5447
public-hoist-pattern[]=*eslint*
# pnpm v10 ignores build scripts by default. The plugin build pipeline needs
# lifecycle scripts for dprint/esbuild/etc., so allow them in CI and locally.
allow-build=*